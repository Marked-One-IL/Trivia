<Window x:Class="Client.MyStatusWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Client"
        mc:Ignorable="d"
        Background="#E6F0FA"
        Title="My Status"
        Height="800"
        Width="800"
        ResizeMode="NoResize">

    <Grid>
        <Label Content="Personal Statistics" HorizontalAlignment="Left" VerticalAlignment="Top" FontFamily="Comic Sans MS" Height="90" Width="427" FontSize="40" Margin="198,25,0,0"/>
        <Label x:Name="gameCount" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="111,194,0,0" RenderTransformOrigin="-1.775,-2.753" Height="89" Width="601" FontSize="30" FontFamily="Comic Sans MS"/>
        <Label x:Name="numOfRightAnwers" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="111,303,0,0" RenderTransformOrigin="-1.775,-2.753" Height="89" Width="601" FontSize="30" FontFamily="Comic Sans MS"/>
        <Label x:Name="numOfAnswers" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="111,418,0,0" RenderTransformOrigin="-1.775,-2.753" Height="88" Width="601" FontSize="30" FontFamily="Comic Sans MS"/>
        <Label x:Name="avgTimePerAnswer" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="111,532,0,0" RenderTransformOrigin="-1.775,-2.753" Height="88" Width="601" FontSize="30" FontFamily="Comic Sans MS"/>
        <Label x:Name="playerScore" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="111,643,0,0" RenderTransformOrigin="-1.775,-2.753" Height="88" Width="601" FontSize="30" FontFamily="Comic Sans MS"/>

        <Button x:Name="GoBackButton" Content="->" Width="51" FontSize="25" Height="42" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="690,36,0,0" Click="Click_GoBack" FontFamily="Comic Sans MS" RenderTransformOrigin="0.497,0.609"/>
    </Grid>
</Window>
