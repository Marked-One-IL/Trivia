<Window x:Class="Client.MenuWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Client"
        mc:Ignorable="d"
        Background="#E6F0FA"
        Title="Menu"
        Height="800"
        Width="800"
        ResizeMode="NoResize">

    <Grid>
        <Label x:Name ="MenuLabel" Content="Menu" FontSize="50" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" HorizontalAlignment="Center" VerticalAlignment="Top" Width="252" Height="81" RenderTransformOrigin="-0.041,-0.124" FontFamily="Comic Sans MS" Margin="0,1,0,0"/>
        <Label x:Name ="UserLabel" Content="" FontSize="25" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" HorizontalAlignment="Center" VerticalAlignment="Top" Width="780" Height="81" RenderTransformOrigin="-0.041,-0.124" FontFamily="Comic Sans MS" Margin="0,75,0,0"/>
        <Button x:Name="SignoutButton" Content="Signout" Width="252" FontSize="25" Height="88" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,151,0,0" Click="Click_Signout" FontFamily="Comic Sans MS"/>
        <Button x:Name="JoinRoomButton" Content="Join Room" Width="252" FontSize="25" Height="88" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,264,0,0" Click="Click_Join" FontFamily="Comic Sans MS"/>
        <Button x:Name="CreateRoomButton" Content="Create Room" Width="252" FontSize="25" Height="88" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,377,0,0" Click="Click_CreateRoom" FontFamily="Comic Sans MS" />
        <Button x:Name="MyStatusButton" Content="My Status" Width="252" FontSize="25" Height="88" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,490,0,0" Click="Click_MyStatus" FontFamily="Comic Sans MS"/>
        <Button x:Name="BestScoresButton"  Content="Best Scores" Width="252" FontSize="25" Height="88" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,603,0,0" Click="Click_BestScores" FontFamily="Comic Sans MS"/>
    </Grid>
</Window>
