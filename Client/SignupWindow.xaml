<Window x:Class="Client.SignupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Client"
        mc:Ignorable="d"
        Background="#E6F0FA"
        Title="Signup"
        Height="800"
        Width="800"
        ResizeMode="NoResize">

    <Grid>
        <TextBox x:Name="SignupEmailBox" FontSize="20" Width="590" Height="40" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="151,240,0,0" FontFamily="Comic Sans MS"/>
        <TextBox x:Name="SignupUsernameBox" FontSize="20" Width="590" Height="38" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="151,296,0,0" FontFamily="Comic Sans MS"/>
        <TextBox x:Name="SignupPasswordBox" FontSize="20" Width="590" Height="40" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="151,352,0,0" FontFamily="Comic Sans MS"/>

        <Label x:Name ="EmailLabel" Content="Email" FontSize="20" Margin="10,240,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" Width="94" Height="40" RenderTransformOrigin="-0.041,-0.124" FontFamily="Comic Sans MS"/>
        <Label x:Name ="UsernameLabel" Content="Username" FontSize="20" Margin="10,296,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" Width="104" Height="38" RenderTransformOrigin="-0.041,-0.124" FontFamily="Comic Sans MS"/>
        <Label x:Name ="PasswordLabel" Content="Password" FontSize="20" Margin="10,352,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" Width="94" Height="40" RenderTransformOrigin="-0.041,-0.124" FontFamily="Comic Sans MS"/>

        <Button x:Name="SignupButton" Content="Signup" Width="252" FontSize="25" Height="88" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,414,0,0" Click="Click_Signup" FontFamily="Comic Sans MS"/>

        <Button x:Name="GoBackButton" Content="->" Width="51" FontSize="25" Height="42" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="690,36,0,0" Click="Click_GoBack" FontFamily="Comic Sans MS" RenderTransformOrigin="0.497,0.609"/>
    </Grid>
</Window>
