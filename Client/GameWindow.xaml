<Window x:Class="Client.GameWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Client"
        mc:Ignorable="d"
        Background="#E6F0FA"
        Title="Game"
        Height="800"
        Width="800"
        ResizeMode="NoResize">

    <Grid>
        <Label x:Name="correctAnswers" FontFamily="Comic Sans MS" Content="Correct Answers - 0" VerticalAlignment="Top" HorizontalAlignment="Left" Foreground="green" Height="57" Width="245" FontSize="20" Margin="155,28,0,0"/>
        <Label x:Name="wrongAnswers" FontFamily="Comic Sans MS" Content="Wrong Answers - 0" VerticalAlignment="Top" HorizontalAlignment="Right" Foreground="red" Height="58" Width="245" FontSize="20" Margin="0,28,155,0"/>
        <Label x:Name="QuestionLabel" FontFamily="Comic Sans MS" Content="" FontSize="20" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" HorizontalAlignment="Center" VerticalAlignment="Top" Height="99" Width="744" Margin="0,100,0,0" RenderTransformOrigin="0.513,0.758">
            <Label.ContentTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding}" TextWrapping="Wrap"/>
                </DataTemplate>
            </Label.ContentTemplate>
        </Label>
        <Button x:Name="GoBackButton" Content="->" Width="51" FontSize="25" Height="42" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="690,36,0,0" Click="Click_GoBack" FontFamily="Comic Sans MS" RenderTransformOrigin="0.497,0.609"/>

        <Button x:Name="Answer0Button" Content="" Width="744" FontSize="20" Height="88" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,224,0,0" FontFamily="Comic Sans MS" Click="Click_Answer0"/>
        <Button x:Name="Answer1Button" Content="" Width="744" FontSize="20" Height="88" HorizontalAlignment="Center" VerticalAlignment="Top" FontFamily="Comic Sans MS" Click="Click_Answer1" Margin="0,346,0,0"/>
        <Button x:Name="Answer2Button" Content="" Width="744" FontSize="20" Height="88" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,470,0,0" FontFamily="Comic Sans MS" Click="Click_Answer2"/>
        <Button x:Name="Answer3Button" Content="" Width="744" FontSize="20" Height="88" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,593,0,0" FontFamily="Comic Sans MS" Click="Click_Answer3"/>

        <Border x:Name="timeBorder" VerticalAlignment="Top" HorizontalAlignment="Center" Width="78" Height="60" BorderBrush="Black" BorderThickness="3" Margin="0,693,0,0"/>
        <Label x:Name="TimeLabel" FontFamily="Comic Sans MS" Content="" FontSize="30" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" HorizontalAlignment="Center" VerticalAlignment="Top" Height="75" Width="78" Margin="0,688,0,0" RenderTransformOrigin="0.513,0.758"/>

        <Label x:Name="waitingLabel" FontFamily="Comic Sans MS" FontSize="30" HorizontalAlignment="Center" VerticalAlignment="Center" Content="" HorizontalContentAlignment="Center" Width="631" Visibility="Collapsed"/>
      
        <Label x:Name="ResultsLabel" FontFamily="Comit Sans MS" FontSize="30" HorizontalAlignment="Left" VerticalAlignment="Center" Height="784" Width="685" Visibility="Collapsed">
            <Label.ContentTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding}" TextWrapping="Wrap"/>
                </DataTemplate>
            </Label.ContentTemplate>
        </Label>
    </Grid>
</Window>
