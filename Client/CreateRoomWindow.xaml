<Window x:Class="Client.CreateRoomWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Client"
        mc:Ignorable="d"
        Background="#E6F0FA"
        Title="Create Room"
        Height="800"
        Width="800"
        ResizeMode="NoResize">
    
    <Grid>
        <Label Content="Create Room" HorizontalAlignment="Center" VerticalAlignment="Top" Height="84" Width="310" FontSize="50" FontFamily="Comic Sans MS"/>

        <Label Content="Room Name" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="82,144,0,0" Height="57" Width="164" FontSize="20" FontFamily="Comic Sans MS"/>
        <TextBox x:Name="RoomName" HorizontalAlignment="Left" VerticalAlignment="Top" Height="38" Width="294" Margin="325,144,0,0" FontSize="20" FontFamily="Comic Sans MS"/>

        <Label Content="Number Of Players" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="82,213,0,0" Height="57" Width="213" FontSize="20" RenderTransformOrigin="0.5,0.5" FontFamily="Comic Sans MS"/>
        <TextBox x:Name="playerCount" HorizontalAlignment="Left" VerticalAlignment="Top" Height="38" Width="294" Margin="325,214,0,0" FontSize="20" FontFamily="Comic Sans MS"/>

        <Label Content="Number Of Questions" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="82,284,0,0" Height="57" Width="238" FontSize="20" FontFamily="Comic Sans MS"/>
        <TextBox x:Name="QuestionCount" HorizontalAlignment="Left" VerticalAlignment="Top" Height="38" Width="294" Margin="325,284,0,0" FontSize="20" FontFamily="Comic Sans MS"/>

        <Label Content="Time Per Question" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="82,354,0,0" Height="57" Width="213" FontSize="20" FontFamily="Comic Sans MS"/>
        <TextBox x:Name="timePerQuestion" HorizontalAlignment="Left" VerticalAlignment="Top" Height="38" Width="294" Margin="325,354,0,0" FontSize="20" FontFamily="Comic Sans MS"/>

        <Button Content="Create Room" HorizontalAlignment="Center" VerticalAlignment="Top" Click="Click_CreateRoom" FontFamily="Comic Sans MS" Margin="0,522,0,0" Height="110" Width="268" FontSize="40"/>
        <Button x:Name="GoBackButton" Content="->" Width="51" FontSize="25" Height="42" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="690,36,0,0" Click="Click_GoBack" FontFamily="Comic Sans MS" RenderTransformOrigin="0.497,0.609"/>
    </Grid>
</Window>
